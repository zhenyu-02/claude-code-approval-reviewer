# Required: API key for an Anthropic Messages API compatible endpoint.
export ANTHROPIC_API_KEY="replace-me"

# Optional: set this when using an Anthropic-compatible proxy, such as a
# claude-code-deepseek style proxy. Do not set it for the official Anthropic API.
# export ANTHROPIC_BASE_URL="http://127.0.0.1:8082"

# Optional: override the reviewer model. The endpoint must understand this model.
# export ANTHROPIC_MODEL="claude-sonnet-4-5"
