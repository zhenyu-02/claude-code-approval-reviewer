{
  "turns_to_read": 2,
  "max_assistant_text_chars": 1000,
  "max_user_prompt_chars": 500,
  "hard_deny_patterns": [
    {
      "pattern": "rm\\s+-rf\\s+/(\\s|$|\\*)",
      "reason": "删除根目录"
    },
    {
      "pattern": "rm\\s+-rf\\s+~(/?\\s|$|\\*)",
      "reason": "删除 home 目录"
    },
    {
      "pattern": "rm\\s+-rf\\s+\\$HOME",
      "reason": "删除 home 目录"
    },
    {
      "pattern": "curl\\b.*\\|\\s*(ba)?sh\\b",
      "reason": "下载并执行远程脚本"
    },
    {
      "pattern": "wget\\b.*\\|\\s*(ba)?sh\\b",
      "reason": "下载并执行远程脚本"
    },
    {
      "pattern": "git\\s+push.*--force.*\\b(main|master)\\b",
      "reason": "force push 到受保护分支"
    },
    {
      "pattern": "git\\s+push.*--force-with-lease.*\\b(main|master)\\b",
      "reason": "force push 到受保护分支"
    },
    {
      "pattern": ">\\s*\\.env(\\s|$)",
      "reason": "覆写 .env"
    },
    {
      "pattern": "chmod\\s+-R\\s+777\\s+/",
      "reason": "全盘权限放开"
    },
    {
      "pattern": "dd\\s+if=.*of=/dev/[sh]d",
      "reason": "直写磁盘设备"
    }
  ],
  "hard_deny_paths": [
    ".env",
    ".ssh/id_rsa",
    ".ssh/id_ed25519",
    ".aws/credentials",
    ".gnupg/",
    "credentials.json",
    "secrets/"
  ],
  "fast_path_allow_tools": [
    "Read",
    "Grep",
    "Glob",
    "WebSearch"
  ],
  "fast_path_allow_bash": [
    "^git\\s+status",
    "^git\\s+diff",
    "^git\\s+log",
    "^git\\s+show",
    "^git\\s+branch",
    "^ls\\b",
    "^cat\\b",
    "^pwd$",
    "^echo\\b",
    "^pytest\\b",
    "^npm\\s+(test|run\\s+test)",
    "^npx\\s+pytest",
    "^rg\\b",
    "^head\\b",
    "^tail\\b",
    "^wc\\b",
    "^file\\b"
  ],
  "llm": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-5",
    "api_key_env": "ANTHROPIC_API_KEY",
    "base_url_env": "ANTHROPIC_BASE_URL",
    "max_tokens": 1024,
    "timeout_seconds": 45,
    "temperature": 0
  },
  "reviewer_allowed_tools": [
    "Read",
    "Grep",
    "Glob"
  ],
  "reviewer_max_turns": 3,
  "llm_tool_input_spill_threshold": 4000,
  "llm_tool_input_preview_chars": 2000,
  "pre_tool_use_active_modes": [
    "bypassPermissions"
  ],
  "circuit_breaker": {
    "enabled": true,
    "state_file": "runtime/circuit_breaker.json",
    "max_consecutive_denials": 3,
    "window_size": 50,
    "max_denials_in_window": 10
  },
  "log_file": "runtime/reviewer.log",
  "fail_closed": true,
  "file_tracker": {
    "enabled": true,
    "state_file": "runtime/file_tracker.json",
    "max_sessions": 50,
    "max_files_per_session": 200
  },
  "approval_records": {
    "enabled": true,
    "file": "runtime/approval_records.jsonl",
    "max_tool_input_chars": 200000,
    "redact_markers": []
  }
}
